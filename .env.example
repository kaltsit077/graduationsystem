# 数据库配置
MYSQL_ROOT_PASSWORD=请修改为强密码
MYSQL_PASSWORD=请修改为强密码
DB_HOST=mysql
DB_PORT=3306
DB_NAME=graduation_topic
DB_USER=root
DB_PASSWORD=请修改为强密码

# JWT 配置
# 注意：HS512 算法要求密钥至少 512 位（64 字节）
# 可以使用以下命令生成：powershell -Command "[Convert]::ToBase64String((1..64 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))"
JWT_SECRET=请生成64字节的Base64密钥
JWT_EXPIRATION=120

# 管理员配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请修改为强密码
ADMIN_REAL_NAME=系统管理员
ADMIN_AUTO_CREATE=false

# 公网部署时必须配置：允许的前端访问来源（逗号分隔，不要空格）
# 示例：CORS_ALLOWED_ORIGINS=https://menu.yourdomain.com,http://menu.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173

